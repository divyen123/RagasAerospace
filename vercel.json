{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/frontend/static/$1"
    },
    {
      "src": "/drone-bg.mp4",
      "dest": "/frontend/drone-bg.mp4"
    },
    {
      "src": "/mission-drone.mp4",
      "dest": "/frontend/mission-drone.mp4"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
